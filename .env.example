SPRING_PROFILES_ACTIVE=prod
SERVER_PORT=8080

# Docker Compose app container should connect to the db service hostname.
DB_URL=jdbc:mysql://db:3306/quiz_platform
# MySQL container credentials (required, do not use root/root in real deployments)
MYSQL_ROOT_PASSWORD=change-me-root-password
MYSQL_USER=quiz_app
MYSQL_PASSWORD=change-me-app-password

# App database credentials (must match MYSQL_USER / MYSQL_PASSWORD for docker-compose defaults)
DB_USERNAME=quiz_app
DB_PASSWORD=change-me-app-password

# Required JWT secret: base64-encoded random key (example: openssl rand -base64 48)
# Replace this sample with your own strong key before production use.
JWT_SECRET_BASE64=cmVwbGFjZS13aXRoLXN0cm9uZy1iYXNlNjQtc2VjcmV0
JWT_EXPIRATION_SECONDS=3600

# Allowed frontend origins for CORS (comma-separated, no wildcard in production)
APP_ALLOWED_ORIGINS=http://localhost:3000,https://quiz.example.com
